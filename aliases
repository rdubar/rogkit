INSTALL=~/opt
ROGKIT="$INSTALL/rogkit"
ROGKIT_PACKAGE="$ROGKIT/rogkit_package" # The root of the Python package

# Set PYTHONPATH to include the directory containing the rogkit package
export PYTHONPATH="$ROGKIT:$PYTHONPATH"

alias rogkit='cat "$ROGKIT/README.md" | grep "[|]"'

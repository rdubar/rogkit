# ------------------------------------------------------------------------------
# Environment Configuration
# ------------------------------------------------------------------------------
INSTALL=~/dev
ROGKIT="$INSTALL/rogkit"
ROGKIT_PACKAGE="$ROGKIT/rogkit_package"
ROGKIT_GO="$ROGKIT/go"
ROGKIT_GO_BIN="$ROGKIT_GO/bin"

# Helper function to run Python via uv in rogkit directory
# Passes original working directory via ROGKIT_CWD environment variable
rogkit_py() {
    ROGKIT_CWD="$PWD" uv run --directory "$ROGKIT" python "$@"
}

# Add rogkit package to Python path
export PYTHONPATH="$ROGKIT:$PYTHONPATH"

# Ensure Go binaries are available on PATH
if [ -d "$ROGKIT_GO_BIN" ] && [[ ":$PATH:" != *":$ROGKIT_GO_BIN:"* ]]; then
    export PATH="$PATH:$ROGKIT_GO_BIN"
fi


#!/usr/bin/env bash
# ==============================================================================
# RogKit Shell Aliases
# ==============================================================================
# Professional utility toolkit for system administration, media management,
# and productivity tools. Source this file in your shell configuration:
#   source ~/dev/rogkit/aliases

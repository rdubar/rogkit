alias files='python -m rogkit_package.bin.files "$@"'
alias heic='python -m rogkit_package.bin.heic "$@"'
alias location='python -m rogkit_package.bin.location "$@"'
alias loc='python -m rogkit_package.bin.location "$@"'
alias media='python -m rogkit_package.media.media_main "$@"'
alias m='python -m rogkit_package.media.media_main "$@"'
alias pw='python -m rogkit_package.bin.pw "$@"'
alias purge='python -m rogkit_package.bin.purge "$@"'

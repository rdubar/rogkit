#!/bin/bash
#
# RogKit comprehensive updater
#

show_help() {
    echo "Usage: $0 [OPTIONS]"
    echo
    echo "Options:"
    echo "  --full        Perform full-upgrade (default is upgrade + dist-upgrade only)"
    echo "  -h, --help    Show this help message and exit"
    echo
    echo "Examples:"
    echo "  $0            Run normal upgrade without full-upgrade"
    echo "  $0 --full     Run upgrade and full-upgrade"
}

# --- Parse args ---
DO_FULL=0
for arg in "$@"; do
    case $arg in
        --full) DO_FULL=1 ;;
        -h|--help) show_help; exit 0 ;;
        *) echo "Unknown option: $arg"; show_help; exit 1 ;;
    esac
done

echo "RogKit comprehensive updater"

start_time=$(date +%s)

# Capture system versions before upgrade
system_info_before=$(lsb_release -a 2>/dev/null)
kernel_version_before=$(uname -r)

echo "Updating package lists..."
sudo apt update

echo "Upgrading packages..."
sudo apt upgrade -y

echo "Performing dist-upgrade..."
sudo apt dist-upgrade -y

# Check if a full-upgrade would do more
if [ $DO_FULL -eq 1 ]; then
    echo "Performing full-upgrade (as requested)..."
    sudo apt full-upgrade -y
else
    echo "Skipping full-upgrade (run with --full to enable)."

    # Warn if additional upgrades are pending that require full-upgrade
    FULL_UPGRADE_CHECK=$(apt list --upgradable 2>/dev/null | grep -v "Listing..." | wc -l)
    if [ "$FULL_UPGRADE_CHECK" -gt 0 ]; then
        echo "⚠️  WARNING: $FULL_UPGRADE_CHECK packages are still upgradable."
        echo "   Run with --full if you want to apply them."
        apt list --upgradable 2>/dev/null | grep -v "Listing..."
    fi
fi

echo "Checking for and fixing broken dependencies..."
sudo apt --fix-broken install -y

echo "Cleaning up..."
sudo apt autoremove -y

# Check if a reboot is required
if [ -f /var/run/reboot-required ]; then
    echo 'Reboot required. Rebooting now...'
    sudo reboot
else
    echo 'Update and upgrade complete. No reboot required.'
fi

end_time=$(date +%s)
total_time=$((end_time - start_time))

# Capture system versions after upgrade
system_info_after=$(lsb_release -a 2>/dev/null)
kernel_version_after=$(uname -r)

if [ "$system_info_before" != "$system_info_after" ] || [ "$kernel_version_before" != "$kernel_version_after" ]; then
    echo "System versions have been updated."
    echo "Before upgrade:"
    echo "$system_info_before"
    echo "Kernel version: $kernel_version_before"
    echo
    echo "After upgrade:"
    echo "$system_info_after"
    echo "Kernel version: $kernel_version_after"
    echo
else
    echo "No changes in system versions."
fi

echo "Total time taken: $((total_time / 60)) minutes and $((total_time % 60)) seconds."